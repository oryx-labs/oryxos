<?xml version="1.0" encoding="UTF-8"?>
<!--
  OryxOS structured logging.
  - default (dev): colored, human-readable console pattern
  - profile=prod : single-line JSON via LogstashEncoder, carries the traceId MDC field
  All logging goes through SLF4J; System.out is forbidden by the coding rules.
-->
<configuration>
    <!-- Registers Spring Boot's %clr / %wEx converters and base properties used below. -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_PATTERN"
              value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr([%X{traceId:-}]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m %kvp%n%wEx"/>

    <!-- Development: colored console -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="io.oryxos" level="DEBUG"/>
    </springProfile>

    <!-- Production: structured JSON -->
    <springProfile name="prod">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <customFields>{"application":"oryxos"}</customFields>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
        <logger name="io.oryxos" level="INFO"/>
    </springProfile>
</configuration>
